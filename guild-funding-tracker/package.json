{
  "name": "guild-funding-tracker",
  "version": "1.0.0",
  "description": "Standalone Discord bot for tracking guild monthly funding",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d bot",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f bot",
    "docker:test": "docker compose run --rm test"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.13.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
