# Required — obtain from the Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Optional — override defaults as needed
# DATABASE_PATH: path inside the container; /data is the Docker named volume mount point
DATABASE_PATH=/data/tracker.db
DEFAULT_HOURLY_COST=0.06
STALE_EMBED_THRESHOLD_HOURS=6
LOG_LEVEL=info
NODE_ENV=production
